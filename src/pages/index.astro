---
import Layout from '../layouts/Layout.astro';
import Terminal from '../components/Terminal.astro';
import KeyBlock from '../components/KeyBlock.astro';
import GhostFetch from '../components/GhostFetch.astro';
---

<Layout title="GhostKellz GPG Identity">
  <main class="min-h-screen py-12 px-4 md:px-8">
    <div class="max-w-4xl mx-auto">
      <!-- Header -->
      <header class="text-center mb-12">
        <div class="mb-6 relative inline-block">
          <div class="absolute inset-0 bg-ghost-cyan/20 rounded-full blur-xl animate-pulse"></div>
          <img
            src="/assets/AVATAR-GhostKellz.png"
            alt="GhostKellz"
            class="relative w-32 h-32 md:w-40 md:h-40 mx-auto rounded-full border-2 border-ghost-cyan shadow-lg shadow-ghost-cyan/30"
          />
        </div>
        <h1 class="text-3xl md:text-4xl font-bold text-ghost-cyan animate-pulse-glow mb-4">
          GhostKellz
        </h1>
        <p class="text-ghost-muted text-lg">
          GPG Verified Identity
        </p>
        <p class="text-ghost-text mt-2">
          Official GPG key for signing projects, commits, and communications.
        </p>
      </header>

      <!-- Terminal Demo -->
      <section class="mb-16">
        <h2 class="text-xl font-bold text-ghost-cyan mb-6 flex items-center gap-2">
          <span class="text-ghost-glow">$</span> Verify Signatures
        </h2>
        <Terminal />
      </section>

      <!-- Key Block -->
      <section class="mb-16">
        <h2 class="text-xl font-bold text-ghost-cyan mb-6 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path>
          </svg>
          Public Key
        </h2>
        <KeyBlock />
      </section>

      <!-- How to Verify -->
      <section class="mb-16">
        <h2 class="text-xl font-bold text-ghost-cyan mb-6 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
          </svg>
          How to Verify
        </h2>
        <div class="grid gap-4 md:grid-cols-2">
          <!-- Import from WKD -->
          <div class="bg-ghost-surface border border-ghost-border rounded-lg p-4" x-data="{ copied: false }">
            <h3 class="text-ghost-cyan font-semibold mb-2 text-sm">Import via WKD</h3>
            <div class="relative">
              <code class="block bg-ghost-bg rounded p-3 text-xs text-ghost-muted overflow-x-auto">gpg --locate-keys ckelley@ghostkellz.sh</code>
              <button
                @click="navigator.clipboard.writeText('gpg --locate-keys ckelley@ghostkellz.sh'); copied = true; setTimeout(() => copied = false, 2000)"
                class="absolute top-2 right-2 text-ghost-muted hover:text-ghost-cyan text-xs"
              >
                <span x-show="!copied">Copy</span>
                <span x-show="copied" class="text-green-400">Copied!</span>
              </button>
            </div>
          </div>

          <!-- Import from URL -->
          <div class="bg-ghost-surface border border-ghost-border rounded-lg p-4" x-data="{ copied: false }">
            <h3 class="text-ghost-cyan font-semibold mb-2 text-sm">Import from URL</h3>
            <div class="relative">
              <code class="block bg-ghost-bg rounded p-3 text-xs text-ghost-muted overflow-x-auto">curl -sL https://ghostkellz.sh/ghostkellz_pubkey.asc | gpg --import</code>
              <button
                @click="navigator.clipboard.writeText('curl -sL https://ghostkellz.sh/ghostkellz_pubkey.asc | gpg --import'); copied = true; setTimeout(() => copied = false, 2000)"
                class="absolute top-2 right-2 text-ghost-muted hover:text-ghost-cyan text-xs"
              >
                <span x-show="!copied">Copy</span>
                <span x-show="copied" class="text-green-400">Copied!</span>
              </button>
            </div>
          </div>

          <!-- Verify Signature -->
          <div class="bg-ghost-surface border border-ghost-border rounded-lg p-4" x-data="{ copied: false }">
            <h3 class="text-ghost-cyan font-semibold mb-2 text-sm">Verify a Signature</h3>
            <div class="relative">
              <code class="block bg-ghost-bg rounded p-3 text-xs text-ghost-muted overflow-x-auto">gpg --verify file.sig file</code>
              <button
                @click="navigator.clipboard.writeText('gpg --verify file.sig file'); copied = true; setTimeout(() => copied = false, 2000)"
                class="absolute top-2 right-2 text-ghost-muted hover:text-ghost-cyan text-xs"
              >
                <span x-show="!copied">Copy</span>
                <span x-show="copied" class="text-green-400">Copied!</span>
              </button>
            </div>
          </div>

          <!-- Show Fingerprint -->
          <div class="bg-ghost-surface border border-ghost-border rounded-lg p-4" x-data="{ copied: false }">
            <h3 class="text-ghost-cyan font-semibold mb-2 text-sm">Check Fingerprint</h3>
            <div class="relative">
              <code class="block bg-ghost-bg rounded p-3 text-xs text-ghost-muted overflow-x-auto">gpg --fingerprint ckelley@ghostkellz.sh</code>
              <button
                @click="navigator.clipboard.writeText('gpg --fingerprint ckelley@ghostkellz.sh'); copied = true; setTimeout(() => copied = false, 2000)"
                class="absolute top-2 right-2 text-ghost-muted hover:text-ghost-cyan text-xs"
              >
                <span x-show="!copied">Copy</span>
                <span x-show="copied" class="text-green-400">Copied!</span>
              </button>
            </div>
          </div>
        </div>
      </section>

      <!-- Key Details -->
      <section class="mb-16">
        <h2 class="text-xl font-bold text-ghost-cyan mb-6 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          Key Details
        </h2>
        <div class="bg-ghost-surface border border-ghost-border rounded-lg p-6">
          <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
            <div>
              <span class="text-ghost-muted text-sm">Algorithm</span>
              <p class="text-ghost-text font-mono">Ed25519 / Cv25519</p>
            </div>
            <div>
              <span class="text-ghost-muted text-sm">Key ID</span>
              <p class="text-ghost-glow font-mono">777538754BA2B57D</p>
            </div>
            <div>
              <span class="text-ghost-muted text-sm">Created</span>
              <p class="text-ghost-text font-mono">2025-04-11</p>
            </div>
            <div>
              <span class="text-ghost-muted text-sm">Expires</span>
              <p class="text-green-400 font-mono">2027-04-05</p>
            </div>
            <div>
              <span class="text-ghost-muted text-sm">UID</span>
              <p class="text-ghost-text font-mono text-sm">GhostKellz &lt;ckelley@ghostkellz.sh&gt;</p>
            </div>
            <div>
              <span class="text-ghost-muted text-sm">Discovery</span>
              <p class="text-ghost-text font-mono text-sm">WKD / DANE</p>
            </div>
          </div>
        </div>
      </section>

      <!-- GitHub -->
      <section class="mb-16">
        <h2 class="text-xl font-bold text-ghost-cyan mb-6 flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </h2>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="https://github.com/ghostkellz/arch"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 bg-ghost-surface border border-ghost-border hover:border-ghost-cyan px-5 py-3 rounded-lg transition-all hover:shadow-lg hover:shadow-ghost-cyan/10 hover:-translate-y-1"
          >
            <svg class="w-5 h-5 text-[#1793D1]" viewBox="0 0 24 24" fill="currentColor">
              <path d="M11.39.605C10.376 3.092 9.764 4.72 8.635 7.132c.693.734 1.543 1.589 2.923 2.554-1.484-.396-2.543-.863-3.384-1.407C6.848 10.998 5 14.478 3.07 18.964c2.13-1.553 3.853-2.53 5.58-2.96-.03-.81-.112-1.634-.133-2.202-.135-2.003-.075-2.453-.075-2.453s.373 1.06.684 2.395c.094.552.18 1.075.243 1.543 1.7-.148 3.453.066 5.314.749a16.7 16.7 0 00-.354-1.47c-.606-2.108-.96-3.433-.96-3.433s.666 1.318 1.32 3.104c.224.638.47 1.4.695 2.207 1.468.752 3.04 1.786 4.846 3.207-.377-1.032-.76-1.96-1.146-2.842l-.008-.015c-1.266-2.904-2.463-5.263-3.753-7.612-.848.527-1.9.986-3.394 1.374 1.4-.947 2.261-1.793 2.966-2.51C13.536 4.448 12.568 2.63 11.39.605z"/>
            </svg>
            <span>GhostKellz Arch</span>
          </a>
          <a
            href="https://github.com/ghostkellz"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 bg-ghost-surface border border-ghost-border hover:border-ghost-cyan px-5 py-3 rounded-lg transition-all hover:shadow-lg hover:shadow-ghost-cyan/10 hover:-translate-y-1"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            <span>GhostKellz</span>
          </a>
          <a
            href="https://github.com/CK-Technology"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 bg-ghost-surface border border-ghost-border hover:border-ghost-cyan px-5 py-3 rounded-lg transition-all hover:shadow-lg hover:shadow-ghost-cyan/10 hover:-translate-y-1"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            <span>CK-Technology</span>
          </a>
        </div>
      </section>

      <!-- Social Links -->
      <section class="mb-16">
        <h2 class="text-xl font-bold text-ghost-cyan mb-6 flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
          </svg>
          Connect
        </h2>
        <div class="flex flex-wrap justify-center gap-4">
          <!-- X/Twitter -->
          <a
            href="https://x.com/Gh0stKellz"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 bg-ghost-surface border border-ghost-border hover:border-ghost-cyan px-4 py-2 rounded-lg transition-all hover:shadow-lg hover:shadow-ghost-cyan/10 hover:-translate-y-1"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
            <span>@Gh0stKellz</span>
          </a>

          <!-- LinkedIn -->
          <a
            href="https://www.linkedin.com/in/christopherkelley89/"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 bg-ghost-surface border border-ghost-border hover:border-ghost-cyan px-4 py-2 rounded-lg transition-all hover:shadow-lg hover:shadow-ghost-cyan/10 hover:-translate-y-1"
          >
            <svg class="w-5 h-5 text-[#0A66C2]" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            <span>LinkedIn</span>
          </a>

          <!-- Discord -->
          <div class="flex items-center gap-2 bg-ghost-surface border border-ghost-border px-4 py-2 rounded-lg" x-data="{ copied: false }">
            <svg class="w-5 h-5 text-[#5865F2]" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/>
            </svg>
            <span>ghostkellz.sh</span>
            <button
              @click="navigator.clipboard.writeText('ghostkellz.sh'); copied = true; setTimeout(() => copied = false, 2000)"
              class="text-ghost-muted hover:text-ghost-cyan text-xs ml-1"
            >
              <span x-show="!copied">Copy</span>
              <span x-show="copied" class="text-green-400">Copied!</span>
            </button>
          </div>

          <!-- Facebook -->
          <a
            href="https://www.facebook.com/ckelley89"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 bg-ghost-surface border border-ghost-border hover:border-ghost-cyan px-4 py-2 rounded-lg transition-all hover:shadow-lg hover:shadow-ghost-cyan/10 hover:-translate-y-1"
          >
            <svg class="w-5 h-5 text-[#1877F2]" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            <span>Facebook</span>
          </a>

          <!-- ENS -->
          <div class="flex items-center gap-2 bg-ghost-surface border border-ghost-border px-4 py-2 rounded-lg" x-data="{ copied: false }">
            <svg class="w-5 h-5 text-[#5298FF]" viewBox="0 0 24 24" fill="currentColor">
              <path d="M6.352 6.24L1.218 12.61a.78.78 0 0 0 0 .96l5.134 6.37c.18.22.53.24.73.04l.03-.03a.53.53 0 0 0 .1-.56l-2.09-6.17a.26.26 0 0 1 0-.19l2.09-6.17a.53.53 0 0 0-.1-.56l-.03-.03c-.2-.2-.55-.18-.73.04zm11.296 11.52l5.134-6.37a.78.78 0 0 0 0-.96l-5.134-6.37a.52.52 0 0 0-.73-.04l-.03.03a.53.53 0 0 0-.1.56l2.09 6.17a.26.26 0 0 1 0 .19l-2.09 6.17a.53.53 0 0 0 .1.56l.03.03c.2.2.55.18.73-.04z"/>
            </svg>
            <span class="font-mono">ckelley.eth</span>
            <button
              @click="navigator.clipboard.writeText('ckelley.eth'); copied = true; setTimeout(() => copied = false, 2000)"
              class="text-ghost-muted hover:text-ghost-cyan text-xs ml-1"
            >
              <span x-show="!copied">Copy</span>
              <span x-show="copied" class="text-green-400">Copied!</span>
            </button>
          </div>

          <!-- Email -->
          <a
            href="mailto:ckelley@ghostkellz.sh"
            class="flex items-center gap-2 bg-ghost-surface border border-ghost-border hover:border-ghost-cyan px-4 py-2 rounded-lg transition-all hover:shadow-lg hover:shadow-ghost-cyan/10 hover:-translate-y-1"
          >
            <svg class="w-5 h-5 text-ghost-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <span>ckelley@ghostkellz.sh</span>
          </a>
        </div>
      </section>

